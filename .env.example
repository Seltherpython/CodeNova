# Production Repodata AI Environment Template

# Core Engine
PORT=3000
NODE_ENV=production
GEMINI_API_KEY="AIzaSy..."

# Firebase Client (Frontend - src/services/firebase.ts)
VITE_FIREBASE_API_KEY="AIzaSy..."
VITE_FIREBASE_AUTH_DOMAIN="project.firebaseapp.com"
VITE_FIREBASE_PROJECT_ID="project-id"
VITE_FIREBASE_STORAGE_BUCKET="project.appspot.com"
VITE_FIREBASE_MESSAGING_SENDER_ID="123456789"
VITE_FIREBASE_APP_ID="1:1234..."

# Firebase Admin (Backend - server.ts)
# JSON string of your service account key file
FIREBASE_SERVICE_ACCOUNT='{"type": "service_account", ...}'

# GitHub Integration
# Used as a server-side fallback token (optional - users will supply theirs via GitHub OAuth)
GITHUB_TOKEN="ghp_..."

# --- GitHub OAuth App (Required for "Login with GitHub" button) ---
# 1. Go to: https://github.com/settings/developers
# 2. Click "New OAuth App"
# 3. Homepage URL: https://your-app.com
# 4. Authorization callback URL: https://your-project-id.firebaseapp.com/__/auth/handler
# 5. Copy the Client ID and Secret into Firebase Console > Authentication > Sign-in method > GitHub
# (Repodata never sees the token — it goes directly into Firebase, which extracts it securely)
